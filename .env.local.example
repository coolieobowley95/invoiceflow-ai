# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Groq (AI invoice extraction)
GROQ_API_KEY=

# Slack
# Slack — app credentials (Basic Information page). Used once to run the
# OAuth consent flow at /api/slack/oauth/install, which grants the
# search:read.public user scope needed for the Real-Time Search API.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Base URL used to build the Slack OAuth redirect_uri. Use your Vercel
# deployment URL in production; this exact value (plus /api/slack/oauth/callback)
# must also be added to your Slack app's OAuth & Permissions > Redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Auth (optional)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
